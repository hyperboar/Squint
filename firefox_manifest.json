{
    "name": "Squint",
    "version": "1.1",
    "manifest_version": 3,
    "description": "Press alt+1|2|3|4 to turn everything into a grayscale mush",
    "browser_specific_settings": {
        "gecko": {
            "id": "hyperboar@gmail.com",
            "data_collection_permissions": {
                "required": ["none"]
            }}
    },
    "permissions": ["activeTab", "scripting"], 
    "host_permissions": [
        "https://*/*",
        "file:///*",
        "http://localhost/*"
    ],
    "action": {"default_title": "Press alt+1|2|3|4 to turn everything into a grayscale mush"},
    "content_scripts": [
        {
            "matches": [
                "https://*/*",
                "file:///*",
                "http://localhost/*"],
            "css": ["style.css"],
            "js": ["content.js"]
        }
    ],
    "icons": {
    "16":  "images/16.png",
    "32":  "images/32.png",
    "48":  "images/48.png",
    "128": "images/128.png"
    }
}
